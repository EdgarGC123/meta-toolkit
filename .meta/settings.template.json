{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Base permissions template \u2014 suitable for any toolkit regardless of purpose. Start here and layer in additional templates based on what your toolkit needs.",
  "permissions": {
    "allow": [
      "Read(/**)",
      "Edit(/**)",
      "Write(/**)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(rm *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git config --get*)",
      "Bash(git rev-parse*)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(paste *)",
      "Bash(tr *)",
      "Bash(env*)",
      "Bash(printenv*)",
      "Bash(which *)",
      "Bash(whereis *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(realpath *)",
      "Bash(pwd*)",
      "Bash(whoami*)",
      "Bash(date*)",
      "Bash(echo *)",
      "Bash(printf *)"
    ],
    "deny": [
      "Bash(rm ..*)",
      "Bash(rm -rf ..*)",
      "Bash(rm ~*)",
      "Bash(rm /*)",
      "Bash(mkdir ..*)",
      "Bash(mkdir ~*)",
      "Bash(mkdir /*)",
      "Bash(touch ..*)",
      "Bash(touch ~*)",
      "Bash(touch /*)",
      "Bash(cp * ..*)",
      "Bash(cp * ~*)",
      "Bash(cp * /*)",
      "Bash(mv * ..*)",
      "Bash(mv * ~*)",
      "Bash(mv * /*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /System*)",
      "Bash(rm -rf /Library*)",
      "Bash(rm -rf /Users/*)",
      "Bash(rm -rf /usr*)",
      "Bash(rm -rf /var*)",
      "Bash(rm -rf /etc*)",
      "Bash(rm -rf /bin*)",
      "Bash(rm -rf /sbin*)",
      "Bash(rm -rf /Applications*)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod 777 *)",
      "Bash(chown -R * /)",
      "Bash(git push --force*main*)",
      "Bash(git push --force*master*)",
      "Bash(git push -f*main*)",
      "Bash(git push -f*master*)",
      "Bash(git reset --hard origin/*)",
      "Bash(git clean -fd*)",
      "Bash(security *)",
      "Bash(nmap *)",
      "Bash(tcpdump *)",
      "Bash(netcat *)",
      "Bash(nc *)",
      "Bash(brew install*)",
      "Bash(apt-get install*)",
      "Bash(yum install*)",
      "Bash(npm install -g*)",
      "Bash(pip install --global*)",
      "Bash(launchctl *)",
      "Bash(systemctl *)",
      "Bash(service *)"
    ]
  }
}