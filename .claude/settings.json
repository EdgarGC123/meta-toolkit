{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Accelerator project settings \u2014 committed with the repo. Grants permissions needed to run /start-here, including git detach on generation.",
  "permissions": {
    "allow": [
      "Read(/**)",
      "Edit(/**)",
      "Write(/**)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(stat *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf .meta*)",
      "Bash(rm -rf .claude/skills/start-here*)",
      "Bash(rm START_HERE.md)",
      "Bash(rm bootstrap.py*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git remote*)",
      "Bash(git remote remove *)",
      "Bash(git rev-parse*)",
      "Bash(git init*)",
      "Bash(curl *)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /System*)",
      "Bash(rm -rf /Library*)",
      "Bash(rm -rf /Users/*)"
    ]
  }
}